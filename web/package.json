{
  "name": "rally-annotator-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-extension port of the Rally Annotator VLC tool (Chrome-first, Manifest V3, cross-browser-ready).",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "prepare:wxt": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wxt": "^0.20.26"
  }
}
